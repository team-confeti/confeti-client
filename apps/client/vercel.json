{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "confeti.co.kr"
        }
      ],
      "destination": "https://www.confeti.co.kr/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/api/sitemap.xml" },
    {
      "source": "/s3-proxy/:path*",
      "destination": "https://confeti-s3-prod.s3.ap-northeast-2.amazonaws.com/:path*"
    },
    { "source": "/(.*)", "destination": "/" }
  ]
}
